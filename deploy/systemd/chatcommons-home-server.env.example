# Copy to /etc/chatcommons/<instance>.env with owner root:root and mode 0600.
CHATCOMMONS_COMMUNITY_ID=replace-with-64-hex-character-community-id
# Keep loopback for private smoke tests. Public operation needs a separate review.
CHATCOMMONS_LISTEN=/ip4/127.0.0.1/udp/41001/quic-v1
# Logical JSON bytes occupied by signed event bodies; default shown is 512 MiB.
CHATCOMMONS_MAX_STORE_BYTES=536870912
